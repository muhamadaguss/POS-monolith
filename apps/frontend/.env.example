# URL base API backend (NestJS). Dipakai axios (client) & fetch server (Auth.js).
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Auth.js v5 — kunci enkripsi JWT session (cookie HttpOnly).
# WAJIB di-set. Generate dengan: openssl rand -base64 32
# JANGAN commit nilai asli — isi di .env.local (diabaikan git).
AUTH_SECRET=

# URL kanonik aplikasi (Auth.js). Di dev: http://localhost:3000
AUTH_URL=http://localhost:3000

# Monitoring — Sentry (error tracking). DSN kosong = NONAKTIF (no-op),
# aman untuk lokal & CI. Isi saat deploy untuk mengaktifkan.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# Upload sourcemap (opsional, hanya saat deploy). JANGAN commit token asli.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
