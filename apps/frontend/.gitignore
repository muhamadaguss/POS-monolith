# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# PWA — service worker hasil build Serwist (di-generate saat build, jangan commit)
public/sw.js
public/sw.js.map
public/swe-worker-*.js

# PWA — ikon aplikasi WAJIB di-commit (root .gitignore meng-ignore *.png global,
# jadi negasikan khusus folder ini agar ikut versi).
!public/icons/
!public/icons/*.png

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...kecuali .env.example (placeholder tanpa rahasia) — wajib di-commit
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
