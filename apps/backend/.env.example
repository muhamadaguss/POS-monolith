# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/kasirku_db?schema=public"

# JWT
JWT_ACCESS_SECRET="change-me-to-a-long-random-secret-access"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-to-a-long-random-secret-refresh"
JWT_REFRESH_EXPIRES_IN="7d"

# App
NODE_ENV="development"
PORT=3001
APP_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# Throttle (rate limiting)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Logging (pino) — level: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# Monitoring — Sentry (error tracking)
# DSN kosong = Sentry NONAKTIF (no-op). Isi saat deploy untuk mengaktifkan.
SENTRY_DSN=
# Sampling tracing (0 = mati). Naikkan perlahan di production bila perlu APM.
SENTRY_TRACES_SAMPLE_RATE=0
