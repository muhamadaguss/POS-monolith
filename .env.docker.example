# =============================================================================
# Environment Variables — Production (STB / CasaOS)
# =============================================================================
# Copy file ini menjadi `.env` di direktori yang sama dengan docker-compose.yml.
# JANGAN commit `.env` (sudah ada di .gitignore).
# =============================================================================

# Database
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/kasirku_db?schema=public

# JWT Tokens (generate dengan: openssl rand -base64 32)
JWT_ACCESS_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Backend API
NODE_ENV=production
PORT=3005
APP_URL=http://localhost:3005
FRONTEND_URL=https://frontend.<domain>.trycloudflare.com

# Auth.js (Next.js)
AUTH_SECRET=change-me-to-a-long-random-secret
AUTH_URL=https://frontend.<domain>.trycloudflare.com

# Frontend (di-bake saat docker build)
NEXT_PUBLIC_API_URL=https://api.<domain>.trycloudflare.com/api/v1

# Sentry (isi DSN untuk mengaktifkan error tracking; kosongkan = nonaktif)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# Grafana (log aggregation dashboard)
# Akses: http://<stb-ip>:3200  — login: admin / password di bawah
GRAFANA_ADMIN_PASSWORD=change-me-to-a-strong-password

